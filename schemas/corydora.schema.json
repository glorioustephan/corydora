{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://corydora.dev/schemas/corydora.schema.json",
  "title": "CorydoraConfig",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "git",
    "runtime",
    "modes",
    "agents",
    "scan",
    "execution",
    "todo",
    "paths"
  ],
  "properties": {
    "version": {
      "type": "integer",
      "const": 1
    },
    "git": {
      "type": "object",
      "additionalProperties": false,
      "required": ["isolationMode", "branchPrefix", "trackMarkdownQueues"],
      "properties": {
        "isolationMode": {
          "type": "string",
          "enum": ["worktree", "branch", "current-branch"]
        },
        "branchPrefix": {
          "type": "string"
        },
        "trackMarkdownQueues": {
          "type": "boolean"
        },
        "worktreeRoot": {
          "type": "string"
        }
      }
    },
    "runtime": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "provider",
        "model",
        "maxOutputTokens",
        "requestTimeoutMs",
        "maxRetries",
        "stages"
      ],
      "properties": {
        "provider": {
          "type": "string",
          "enum": [
            "claude-cli",
            "codex-cli",
            "gemini-cli",
            "anthropic-api",
            "openai-api",
            "google-api",
            "bedrock",
            "ollama",
            "fake"
          ]
        },
        "model": {
          "type": "string"
        },
        "fallbackProvider": {
          "type": "string"
        },
        "maxOutputTokens": {
          "type": "integer",
          "minimum": 1
        },
        "requestTimeoutMs": {
          "type": "integer",
          "minimum": 1
        },
        "maxRetries": {
          "type": "integer",
          "minimum": 0
        },
        "stages": {
          "type": "object",
          "additionalProperties": false,
          "required": ["analyze", "fix", "summary"],
          "properties": {
            "analyze": { "$ref": "#/$defs/runtimeStage" },
            "fix": { "$ref": "#/$defs/runtimeStage" },
            "summary": { "$ref": "#/$defs/runtimeStage" }
          }
        }
      }
    },
    "modes": {
      "type": "object",
      "additionalProperties": false,
      "required": ["default", "profiles"],
      "properties": {
        "default": {
          "type": "string",
          "enum": ["auto", "churn", "clean", "refactor", "performance", "linting", "documentation"]
        },
        "profiles": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "auto",
            "churn",
            "clean",
            "refactor",
            "performance",
            "linting",
            "documentation"
          ],
          "properties": {
            "auto": { "$ref": "#/$defs/modeProfile" },
            "churn": { "$ref": "#/$defs/modeProfile" },
            "clean": { "$ref": "#/$defs/modeProfile" },
            "refactor": { "$ref": "#/$defs/modeProfile" },
            "performance": { "$ref": "#/$defs/modeProfile" },
            "linting": { "$ref": "#/$defs/modeProfile" },
            "documentation": { "$ref": "#/$defs/modeProfile" }
          }
        }
      }
    },
    "agents": {
      "type": "object",
      "additionalProperties": false,
      "required": ["enabledCategories", "selectedBuiltinAgents"],
      "properties": {
        "enabledCategories": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["bugs", "performance", "tests", "todo", "features"]
          }
        },
        "selectedBuiltinAgents": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "importedAgentDirectory": {
          "type": "string"
        }
      }
    },
    "scan": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "batchSize",
        "maxConcurrentScans",
        "allowBroadRisk",
        "includeExtensions",
        "excludeDirectories"
      ],
      "properties": {
        "batchSize": {
          "type": "integer",
          "minimum": 1
        },
        "maxConcurrentScans": {
          "type": "integer",
          "minimum": 1
        },
        "allowBroadRisk": {
          "type": "boolean"
        },
        "includeExtensions": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "excludeDirectories": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "execution": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "backgroundByDefault",
        "preventIdleSleep",
        "maxFixesPerRun",
        "maxRuntimeMinutes",
        "backlogTarget",
        "validateAfterFix",
        "maxAnalyzeWorkers",
        "maxFixWorkers",
        "maxAttempts",
        "leaseTtlMinutes"
      ],
      "properties": {
        "backgroundByDefault": {
          "type": "boolean"
        },
        "preventIdleSleep": {
          "type": "boolean"
        },
        "maxFixesPerRun": {
          "type": "integer",
          "minimum": 1
        },
        "maxRuntimeMinutes": {
          "type": "integer",
          "minimum": 1
        },
        "backlogTarget": {
          "type": "integer",
          "minimum": 1
        },
        "validateAfterFix": {
          "type": "boolean"
        },
        "maxAnalyzeWorkers": {
          "type": "integer",
          "minimum": 1
        },
        "maxFixWorkers": {
          "type": "integer",
          "minimum": 1
        },
        "maxAttempts": {
          "type": "integer",
          "minimum": 1
        },
        "leaseTtlMinutes": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "todo": {
      "type": "object",
      "additionalProperties": false,
      "required": ["trackMarkdownFiles", "renderCompletedTasks"],
      "properties": {
        "trackMarkdownFiles": {
          "type": "boolean"
        },
        "renderCompletedTasks": {
          "type": "boolean"
        }
      }
    },
    "paths": {
      "type": "object",
      "additionalProperties": false,
      "required": ["corydoraDir", "stateDir", "logsDir", "runsDir", "agentsDir", "envFile"],
      "properties": {
        "corydoraDir": {
          "type": "string"
        },
        "stateDir": {
          "type": "string"
        },
        "logsDir": {
          "type": "string"
        },
        "runsDir": {
          "type": "string"
        },
        "agentsDir": {
          "type": "string"
        },
        "envFile": {
          "type": "string"
        }
      }
    }
  },
  "$defs": {
    "runtimeStage": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "provider": {
          "type": "string",
          "enum": [
            "claude-cli",
            "codex-cli",
            "gemini-cli",
            "anthropic-api",
            "openai-api",
            "google-api",
            "bedrock",
            "ollama",
            "fake"
          ]
        },
        "model": {
          "type": "string"
        },
        "fallbackProvider": {
          "type": "string",
          "enum": [
            "claude-cli",
            "codex-cli",
            "gemini-cli",
            "anthropic-api",
            "openai-api",
            "google-api",
            "bedrock",
            "ollama",
            "fake"
          ]
        },
        "maxOutputTokens": {
          "type": "integer",
          "minimum": 1
        },
        "requestTimeoutMs": {
          "type": "integer",
          "minimum": 1
        },
        "maxRetries": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "modeProfile": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "agentIds": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "categoryBias": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["bugs", "performance", "tests", "todo", "features"]
          }
        }
      }
    }
  }
}
