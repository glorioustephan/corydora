{
  "name": "corydora",
  "version": "0.3.0",
  "description": "Provider-neutral overnight AI code scrubbing CLI.",
  "keywords": [
    "ai",
    "cli",
    "codex",
    "claude",
    "gemini",
    "automation",
    "refactoring",
    "quality"
  ],
  "license": "MIT",
  "type": "module",
  "packageManager": "pnpm@10.32.1",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/glorioustephan/corydora.git"
  },
  "homepage": "https://github.com/glorioustephan/corydora#readme",
  "bugs": {
    "url": "https://github.com/glorioustephan/corydora/issues"
  },
  "bin": {
    "corydora": "dist/index.js"
  },
  "files": [
    "dist",
    "CHANGELOG.md",
    "logo.webp",
    "README.md",
    "schemas"
  ],
  "scripts": {
    "build": "pnpm clean && tsc -p tsconfig.json",
    "clean": "rimraf dist coverage .artifacts artifacts",
    "check": "pnpm lint && pnpm format:check && pnpm typecheck && pnpm test && pnpm build",
    "commit": "cz",
    "dev": "node --import tsx ./src/index.ts",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "pack:preview": "pnpm build && pnpm pack --pack-destination artifacts",
    "prepublishOnly": "pnpm check",
    "test": "vitest --run",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs"
  },
  "config": {
    "commitizen": {
      "path": "cz-conventional-changelog"
    }
  },
  "engines": {
    "node": ">=20.19.0",
    "pnpm": ">=10.32.1"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.80.0",
    "@aws-sdk/client-bedrock-runtime": "^3.1014.0",
    "@clack/prompts": "^1.1.0",
    "@google/genai": "^1.46.0",
    "commander": "^14.0.3",
    "consola": "^3.4.2",
    "openai": "^6.32.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.5.0",
    "commitizen": "^4.3.1",
    "cz-conventional-changelog": "^3.3.0",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.4.0",
    "prettier": "^3.8.1",
    "rimraf": "^6.1.3",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.1",
    "vitepress": "^1.6.3",
    "vitest": "^4.1.0"
  }
}
